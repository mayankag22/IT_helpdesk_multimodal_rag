# ─────────────────────────────────────────────────────────────────────────────
# multimodal-rag-troubleshooter · Environment Variables
# Copy to .env and fill in your values. Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of your local Ollama instance (default when running via Docker Compose)
OLLAMA_BASE_URL=http://ollama:11434

# Models to use (must be pulled via `ollama pull <model>`)
OLLAMA_LLM_MODEL=llama3.1:8b          # swap to mistral:7b on low-RAM machines
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://mcp-server:8000  # internal Docker network URL
MCP_API_KEY=changeme                   # shared secret between containers

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/vector_store   # mounted Docker volume

# ── Retrieval Settings ────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5
RERANK_TOP_N=3
CRITIC_THRESHOLD=0.70                  # confidence below this triggers fallback

# ── Web Search (Tertiary Fallback) ────────────────────────────────────────────
# Leave blank to use DuckDuckGo (free, no key needed)
TAVILY_API_KEY=

# ── Observability (optional) ──────────────────────────────────────────────────
# Sign up at https://smith.langchain.com/ — free tier: 5000 traces/month
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multimodal-rag-troubleshooter
LANGCHAIN_TRACING_V2=false             # set to true to enable LangSmith

# ── Optional Cloud Escalation ─────────────────────────────────────────────────
# Only used if ENABLE_OPENAI_FALLBACK=true
OPENAI_API_KEY=
ENABLE_OPENAI_FALLBACK=false
